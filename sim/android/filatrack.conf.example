# FilaTrack tablet config. Copy this to the tablet as /sdcard/filatrack.conf:
#     adb push filatrack.conf /sdcard/filatrack.conf
#
# The access_code is a SECRET (printer LAN access code, shown on the printer's
# screen under Settings > WLAN). Keep this file on the tablet only - never
# commit a real one to git.

printer_ip=192.168.2.27
printer_serial=01P00C000000000
access_code=00000000

# optional
brightness=70
wifi_ssid=HomeWiFi
view3d=1                    # screensaver g-code view: 1 = 3D isometric, 0 = 2D top-down
scale_ip=192.168.2.60      # FilaTrack Scale host (fixed IP, or a name if mDNS works)
ntfy_topic=                # ntfy.sh topic for push notifications (empty = off)

# Not in this file (managed on the tablet itself):
#   /sdcard/filatrack_weights.conf   per-slot filament weight/price tracking
#   /sdcard/filatrack_spools.conf    the spool library
#   /sdcard/filatrack_empties.conf   empty-spool weight library
#   /sdcard/filatrack_history.conf   recent-print log

# The web page (http://<tablet>:8080) needs a password. Leave this out and the
# tablet makes one on first start and shows it under Settings > Web password -
# there is no default password to forget to change. Clear the line and restart to
# get a fresh one.
#webui_pass=

# FilaTrack only answers on your own network (10./172.16-31./192.168./169.254.).
# That is the backstop for someone forwarding port 8080 on the router. Set this to
# 1 only if you know exactly what you are exposing, and why.
#allow_remote=0

# Web server port (default 8080). Change it if 8080 clashes with something else on
# the tablet. You can also set it on the tablet under Settings > Printer setup. Must
# be 1024-65535 - a non-root Android app can't bind below 1024, and anything the
# server can't bind falls back to 8080 so you're never locked out.
#webui_port=8080
