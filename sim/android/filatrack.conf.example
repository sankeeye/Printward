# FilaTrack tablet config. Copy this to the tablet as /sdcard/filatrack.conf:
#     adb push filatrack.conf /sdcard/filatrack.conf
#
# The access_code is a SECRET (printer LAN access code, shown on the printer's
# screen under Settings > WLAN). Keep this file on the tablet only - never
# commit a real one to git.

printer_ip=192.168.2.27
printer_serial=01P00C000000000
access_code=00000000

# optional
brightness=70
wifi_ssid=HomeWiFi
view3d=1                    # screensaver g-code view: 1 = 3D isometric, 0 = 2D top-down
scale_ip=192.168.2.60      # FilaTrack Scale host (fixed IP, or a name if mDNS works)
ntfy_topic=                # ntfy.sh topic for push notifications (empty = off)

# Not in this file (managed on the tablet itself):
#   /sdcard/filatrack_weights.conf   per-slot filament weight/price tracking
#   /sdcard/filatrack_spools.conf    the spool library
#   /sdcard/filatrack_empties.conf   empty-spool weight library
#   /sdcard/filatrack_history.conf   recent-print log
