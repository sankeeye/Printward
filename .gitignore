# PlatformIO
.pio
.pioenvs
.piolibdeps
.clang_complete
.gcc-flags.json

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Python (Virtualenvs)
venv/
.venv/
__pycache__/

# Build artifacts
*.bin
*.elf
build_out*.txt

# Bambu Cloud weight relay - has your account password / access token, keep local
tools/config.json
tools/relay_state.json

# Windows shortcut with a machine-specific absolute path - not useful to others
tools/*.lnk

# Tablet printer config - contains the LAN access code (secret). Only the
# .example is tracked; a real pandatouch.conf stays on the device.
pandatouch.conf
!android/**/pandatouch.conf.example
!sim/android/pandatouch.conf.example

# Android build tree / gradle output (third-party SDL/lvgl/mbedtls + APKs are
# reconstructed, not committed - see android/README.md)
android/**/build/
android/**/.gradle/
android/local.properties
*.apk

# Simulator build output
sim/build/