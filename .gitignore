# Build artifacts
*.bin
*.elf
build_out*.txt

# Bambu Cloud weight relay - has your account password / access token, keep local
tools/config.json
tools/relay_state.json

# Windows shortcut with a machine-specific absolute path - not useful to others
tools/*.lnk

# Tablet printer config - contains the LAN access code (secret). Only the
# .example is tracked; a real config stays on the device, never in git.
# All three historical names are listed so an old config (with the access code)
# from before a rename can never be committed by accident.
printward.conf
filatrack.conf
pandatouch.conf
!**/printward.conf.example
!**/pandatouch.conf.example

# Android build tree / gradle output (third-party SDL/lvgl/mbedtls + APKs are
# reconstructed, not committed - see android/README.md)
android/**/build/
android/**/.gradle/
android/local.properties
*.apk

# Simulator build output
sim/build/
de_missing.txt
